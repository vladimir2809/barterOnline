{{#if flagModal}}
    <script>
        alert('Пользователь с таким Email уже существует.');
        window.history.back();
        //console.log({data});
    </script>
{{/if}}
{{#if enterData}}
    <div class="registration" id="registration">
        <form action="/newUser/" class="registration__form" name='registrationForm' id='registrationForm'
                method="POST" enctype="application/x-www-form-urlencoded">
            <p class="registration__title">Регистрация</p>
            <label for="registrationName" class="registration__name-label">Ваше имя</label>
            <br>
            <input type="text" class="registration__name" id="registrationName" name="registrationName">
            <br>        
            <label for="registrationsurName" class="registration__surname-label">Ваша фамилия</label>
            <br>
            <input type="text" class="registration__surname" id="registrationSurname" name="registrationSurname">
            <br>
            <label for="registrationEmail" class="registration__email-label">Ваш email</label>
            <br>
            <input type="text" class="registration__email" id="registrationEmail" name="registrationEmail">
            <br>
            <label for="registrationsurPassword" class="registration__password-label">Ваш пароль </label>
            <br>
            <input type="password" class="registration__password" id="registrationPassword" name="registrationPassword">
            <br>
            <label for="registrationsurPasswordDouble" class="registration__passwordDouble-label">Повторите пароль </label>
            <br>
            <input type="password" class="registration__passwordDouble" id="registrationPasswordDouble" name="registrationPasswordDouble">
            <br>                                                  
            <input type="submit" class="registration__submit" id="registrationSubmit" value="Зарегистрироваться">
        </form> 
    </div>
{{/if}}
<div class="confirmationEmail">
    <form action="" class="confirmationEmail__form">
        <h3 class="confirmationEmail__name">Подтверждение Email</h3>
        <p class="confirmationEmail__text">Для завершения регистрации введите номер, 
                из письма, которое мы отправили на ваш email.</p>
        <label for="confirmationEmailValue" class="confirmationEmail__label">Введите номер</label>
        <br>
        <input type="text" class="confirmationEmail__value" id="confirmationEmailValue">
        <input type="submit" class="confirmationEmail__submit">
        <br>
        <a href="" class="confirmationEmail__cancel">отмена</a>
    </form>
</div>
<script src="/script/registration.js" type="text/javascript"></script>
